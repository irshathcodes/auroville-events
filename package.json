{
  "name": "auroville-events",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "pnpm -r dev",
    "build": "pnpm -r build",
    "check-types": "pnpm -r check-types",
    "dev:native": "pnpm --filter native dev",
    "dev:web": "pnpm --filter web dev",
    "dev:server": "pnpm --filter server dev",
    "db:push": "pnpm --filter @auroville-events/db db:push",
    "db:generate": "pnpm --filter @auroville-events/db db:generate",
    "deploy:prod": "NODE_ENV=production pnpm --filter @auroville-events/infra run deploy",
    "destroy": "pnpm --filter @auroville-events/infra destroy"
  },
  "dependencies": {
    "@auroville-events/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@auroville-events/config": "workspace:*",
    "@cloudflare/workers-types": "catalog:",
    "@types/node": "catalog:",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@10.15.0"
}
